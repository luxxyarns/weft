{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://weft.dev/schemas/v1.0/material.schema.json",
  "title": "WEFT Material",
  "description": "A craft material: yarn, fabric, thread, roving, floss, or any material used in textile crafts.",
  "type": "object",
  "required": ["weft_version", "type", "items"],
  "properties": {
    "weft_version": { "type": "string", "const": "1.0" },
    "type": { "type": "string", "const": "material" },
    "exported_at": { "type": "string", "format": "date-time" },
    "exported_from": {
      "type": "object",
      "properties": {
        "app": { "type": "string" },
        "version": { "type": "string" },
        "platform": { "type": "string" }
      }
    },
    "items": {
      "type": "array",
      "items": { "$ref": "#/$defs/Material" }
    }
  },
  "$defs": {
    "Material": {
      "type": "object",
      "required": ["id", "name", "material_type", "quantity", "status"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "material_type": {
          "type": "string",
          "description": "See 99-taxonomy/material-type.yaml"
        },
        "craft": {
          "type": "array",
          "items": { "type": "string" },
          "description": "See 99-taxonomy/craft.yaml"
        },
        "quantity": { "$ref": "#/$defs/Quantity" },
        "status": {
          "type": "string",
          "description": "See 99-taxonomy/status.yaml (material_status)"
        },
        "acquired_date": { "type": "string", "format": "date" },
        "acquired_from": { "type": "string" },
        "acquired_price": { "$ref": "#/$defs/Money" },
        "color_description": { "type": "string" },
        "color_hex": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
        "color_family": {
          "type": "string",
          "description": "See 99-taxonomy/color-family.yaml"
        },
        "brand": { "type": "string" },
        "product_line": { "type": "string" },
        "notes": { "type": "string" },
        "photos": { "type": "array", "items": { "$ref": "#/$defs/Photo" } },
        "tags": { "type": "array", "items": { "type": "string" } },
        "location": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" },

        "yarn": {
          "type": "object",
          "description": "Yarn-specific fields. Present when material_type is 'yarn'. See 02-material/types/yarn/",
          "additionalProperties": true
        },
        "fabric": {
          "type": "object",
          "description": "Fabric-specific fields. Present when material_type is 'fabric'. See 02-material/types/fabric/",
          "additionalProperties": true
        },
        "roving": {
          "type": "object",
          "description": "Roving-specific fields. Present when material_type is 'roving'. See 02-material/types/roving/",
          "additionalProperties": true
        },
        "thread": {
          "type": "object",
          "description": "Thread-specific fields. Present when material_type is 'thread'.",
          "additionalProperties": true
        },
        "floss": {
          "type": "object",
          "description": "Floss-specific fields. Present when material_type is 'floss'.",
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "Quantity": {
      "type": "object",
      "required": ["value", "unit"],
      "properties": {
        "value": { "type": "number" },
        "unit": { "type": "string", "description": "See 99-taxonomy/unit.yaml" },
        "weight_grams": { "type": "number" },
        "length_meters": { "type": "number" }
      }
    },
    "Money": {
      "type": "object",
      "required": ["amount", "currency"],
      "properties": {
        "amount": { "type": "number" },
        "currency": { "type": "string", "minLength": 3, "maxLength": 3 }
      }
    },
    "Photo": {
      "type": "object",
      "required": ["uri"],
      "properties": {
        "uri": { "type": "string" },
        "is_primary": { "type": "boolean", "default": false },
        "caption": { "type": "string" }
      }
    }
  }
}
