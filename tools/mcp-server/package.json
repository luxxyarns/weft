{
  "name": "mcp-weft",
  "version": "1.0.0",
  "description": "MCP server for WEFT format export from Ravelry — local (stdio) or hosted (HTTP + OAuth 2.0)",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "npm run generate-types && tsc",
    "generate-types": "node scripts/generate-types.js",
    "start": "node dist/index.js",
    "start:hosted": "node dist/hosted.js",
    "dev": "tsx src/index.ts",
    "dev:hosted": "tsx src/hosted.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "express": "^4.21.0",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "json-schema-to-typescript": "^15.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
