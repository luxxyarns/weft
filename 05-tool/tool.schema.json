{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://weft.dev/schemas/v1.0/tool.schema.json",
  "title": "WEFT Tool",
  "description": "Craft tools: needles, hooks, looms, accessories, organized in sets with project assignments and loan tracking.",
  "type": "object",
  "required": ["weft_version", "type", "items"],
  "properties": {
    "weft_version": { "type": "string", "const": "1.0" },
    "type": { "type": "string", "const": "tool" },
    "exported_at": { "type": "string", "format": "date-time" },
    "exported_from": {
      "type": "object",
      "properties": {
        "app": { "type": "string" },
        "version": { "type": "string" },
        "platform": { "type": "string" }
      }
    },
    "items": {
      "type": "array",
      "items": { "$ref": "#/$defs/Tool" }
    },
    "sets": {
      "type": "array",
      "items": { "$ref": "#/$defs/ToolSet" }
    }
  },
  "$defs": {
    "Tool": {
      "type": "object",
      "required": ["id"],
      "properties": {
        "id": { "type": "string" },
        "category": {
          "type": "string",
          "enum": ["needle", "hook", "loom", "wheel", "spindle", "e-spinner", "sewing-machine", "hoop", "frame", "shuttle", "ruler", "rotary-cutter", "cutting-mat", "iron", "accessory", "notion", "other"],
          "description": "Tool category"
        },
        "tool_type": { "type": "string", "description": "Specific type within category. Needles: circular, dpn, straight, interchangeable, cable. Hooks: standard, tunisian, ergonomic, inline, tapered. Looms: floor, table, rigid-heddle, tapestry, inkle, backstrap, card-tablet. Spindles: top-whorl, bottom-whorl, turkish, supported. Hoops: round, oval, scroll-frame, q-snap. Shuttles: tatting-shuttle, tatting-needle, boat-shuttle." },
        "name": { "type": "string" },
        "brand": { "type": "string" },
        "model": { "type": "string" },
        "material": { "type": "string", "description": "What the tool is made of: 'bamboo', 'metal', 'wood', 'plastic', etc." },
        "color": { "type": "string" },

        "metric_size_mm": { "type": "number", "description": "Needle/hook size in mm" },
        "us_size": { "type": "string", "description": "US needle size designation" },
        "hook_size": { "type": "string", "description": "Crochet hook letter designation" },
        "length_cm": { "type": "number", "description": "Total length in cm (tip-to-tip for circulars)" },
        "length_inches": { "type": "number" },
        "cable_length_cm": { "type": "number", "description": "Circular needle: cable length only (separate from tip length)" },
        "tip_type": { "type": "string", "description": "Needle tip shape: sharp, blunt, standard" },
        "hook_head_shape": { "type": "string", "description": "Crochet hook head: inline, tapered" },

        "quantity": { "type": "integer", "default": 1 },

        "shaft_count": { "type": "integer", "description": "Loom: number of shafts" },
        "treadle_count": { "type": "integer", "description": "Loom: number of treadles" },
        "weaving_width_cm": { "type": "number", "description": "Loom: maximum weaving width" },
        "loom_style": { "type": "string", "description": "floor, table, rigid-heddle, tapestry, inkle, backstrap, card-tablet" },

        "drive_system": { "type": "string", "description": "Spinning wheel: scotch-tension, double-drive, irish-tension" },
        "wheel_ratio": { "type": "string", "description": "Spinning wheel: drive ratio (e.g., '8:1')" },
        "whorl_weight_grams": { "type": "number", "description": "Spindle: whorl weight" },

        "machine_brand": { "type": "string", "description": "Sewing machine brand" },
        "machine_model": { "type": "string", "description": "Sewing machine model" },
        "machine_type": { "type": "string", "description": "mechanical, computerized, serger, coverstitch, embroidery, longarm" },

        "hoop_diameter_cm": { "type": "number", "description": "Embroidery hoop/frame diameter or size" },
        "hoop_shape": { "type": "string", "description": "round, oval, square, scroll" },

        "notes": { "type": "string" },
        "is_archived": { "type": "boolean", "default": false },

        "set_id": { "type": "string", "description": "ID of the ToolSet this belongs to" },
        "set_role": { "type": "string", "description": "Role within a set: 'primary', 'secondary', 'cable', etc." },

        "loaned_to": { "type": "string", "description": "Who currently has this tool" },
        "loaned_date": { "type": "string", "format": "date" },

        "project_assignments": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Project IDs this tool is currently assigned to"
        },

        "source": { "type": "string", "enum": ["custom", "imported"], "description": "Whether user-created or imported from platform" },
        "external_ids": { "$ref": "#/$defs/ExternalIds" },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": true
    },

    "ToolSet": {
      "type": "object",
      "required": ["id", "name"],
      "description": "A set of tools that belong together (e.g., interchangeable needle set, hook set).",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "brand": { "type": "string" },
        "notes": { "type": "string" },
        "tool_ids": {
          "type": "array",
          "items": { "type": "string" },
          "description": "IDs of tools in this set"
        },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" }
      }
    },

    "ExternalIds": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    }
  }
}
