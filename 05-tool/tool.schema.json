{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://weft.dev/schemas/v1.0/tool.schema.json",
  "title": "WEFT Tool",
  "description": "Craft tools: needles, hooks, looms, accessories, organized in sets with project assignments and loan tracking.",
  "type": "object",
  "required": ["weft_version", "type"],
  "properties": {
    "weft_version": { "type": "string", "const": "1.0" },
    "type": { "type": "string", "const": "tool" },
    "exported_at": { "type": "string", "format": "date-time" },
    "exported_from": {
      "type": "object",
      "properties": {
        "app": { "type": "string" },
        "version": { "type": "string" },
        "platform": { "type": "string" }
      }
    },
    "items": {
      "type": "array",
      "items": { "$ref": "#/$defs/Tool" }
    },
    "sets": {
      "type": "array",
      "items": { "$ref": "#/$defs/ToolSet" }
    }
  },
  "$defs": {
    "Tool": {
      "type": "object",
      "required": ["id"],
      "properties": {
        "id": { "type": "string" },
        "category": {
          "type": "string",
          "enum": ["needle", "hook", "loom", "wheel", "accessory", "notion", "other"],
          "description": "Tool category"
        },
        "tool_type": { "type": "string", "description": "Specific type: 'circular', 'dpn', 'straight', 'interchangeable', 'fixed', 'crochet_hook', 'tunisian', 'rigid_heddle', etc." },
        "name": { "type": "string" },
        "brand": { "type": "string" },
        "model": { "type": "string" },
        "material": { "type": "string", "description": "What the tool is made of: 'bamboo', 'metal', 'wood', 'plastic', etc." },
        "color": { "type": "string" },

        "metric_size_mm": { "type": "number", "description": "Needle/hook size in mm" },
        "us_size": { "type": "string", "description": "US needle size designation" },
        "hook_size": { "type": "string", "description": "Crochet hook letter designation" },
        "length_cm": { "type": "number", "description": "Tool length in cm (needle length, cable length)" },
        "length_inches": { "type": "number" },

        "quantity": { "type": "integer", "default": 1 },
        "notes": { "type": "string" },
        "is_archived": { "type": "boolean", "default": false },

        "set_id": { "type": "string", "description": "ID of the ToolSet this belongs to" },
        "set_role": { "type": "string", "description": "Role within a set: 'primary', 'secondary', 'cable', etc." },

        "loaned_to": { "type": "string", "description": "Who currently has this tool" },
        "loaned_date": { "type": "string", "format": "date" },

        "project_assignments": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Project IDs this tool is currently assigned to"
        },

        "source": { "type": "string", "enum": ["custom", "imported"], "description": "Whether user-created or imported from platform" },
        "external_ids": { "$ref": "#/$defs/ExternalIds" },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": true
    },

    "ToolSet": {
      "type": "object",
      "required": ["id", "name"],
      "description": "A set of tools that belong together (e.g., interchangeable needle set, hook set).",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "brand": { "type": "string" },
        "notes": { "type": "string" },
        "tool_ids": {
          "type": "array",
          "items": { "type": "string" },
          "description": "IDs of tools in this set"
        },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" }
      }
    },

    "ExternalIds": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    }
  }
}
