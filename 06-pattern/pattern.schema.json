{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/luxxyarns/weft/blob/main/pattern.schema.json",
  "title": "WEFT Pattern",
  "description": "A craft pattern: instructions, recipes, and transformation guides for making something.",
  "type": "object",
  "required": ["weft_version", "type", "items"],
  "properties": {
    "weft_version": { "type": "string", "const": "1.0" },
    "type": { "type": "string", "const": "pattern" },
    "exported_at": { "type": "string", "format": "date-time" },
    "exported_from": {
      "type": "object",
      "properties": {
        "app": { "type": "string" },
        "version": { "type": "string" },
        "platform": { "type": "string" }
      }
    },
    "items": {
      "type": "array",
      "items": { "$ref": "#/$defs/Pattern" }
    }
  },
  "$defs": {
    "Pattern": {
      "type": "object",
      "required": ["id", "name"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },

        "contributors": {
          "type": "array",
          "items": { "$ref": "#/$defs/ContributorRef" },
          "description": "All people involved: designer, tech editor, translator, illustrator, photographer, sample maker."
        },
        "designer": { "$ref": "#/$defs/ContributorRef", "description": "Primary designer (shorthand — also appears in contributors[])" },

        "craft": {
          "type": "array",
          "items": { "type": "string" },
          "description": "See 99-taxonomy/craft.yaml"
        },
        "category": { "$ref": "#/$defs/CategoryRef" },
        "pattern_attributes": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Structured attributes. See 99-taxonomy/pattern-attribute.yaml"
        },
        "difficulty": { "type": "number", "minimum": 1, "maximum": 10 },

        "edition": { "type": "string", "description": "Edition identifier (e.g., '2nd edition', 'v2.1')" },
        "revision": { "type": "string", "description": "Revision/version within an edition" },
        "revision_notes": { "type": "string", "description": "What changed in this revision" },
        "errata": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "date": { "type": "string", "format": "date" },
              "description": { "type": "string" },
              "affected_sections": { "type": "array", "items": { "type": "string" } },
              "correction": { "type": "string" }
            }
          },
          "description": "Known corrections to the published pattern."
        },
        "replaces_pattern_id": { "type": "string", "description": "ID of the pattern this supersedes" },
        "superseded_by_pattern_id": { "type": "string", "description": "ID of the pattern that supersedes this one" },

        "rights": {
          "type": "object",
          "description": "Copyright and usage information.",
          "properties": {
            "copyright_holder": { "type": "string" },
            "copyright_year": { "type": "integer" },
            "license": { "type": "string", "description": "License identifier (e.g., 'personal-use', 'commercial-allowed', 'CC-BY-4.0', 'all-rights-reserved')" },
            "usage_policy": { "type": "string", "description": "Free-text usage terms (e.g., 'Sell finished items with credit')" }
          }
        },

        "published_date": { "type": "string", "format": "date" },
        "generally_available": { "type": "string", "format": "date" },

        "sources": {
          "type": "array",
          "items": { "$ref": "#/$defs/PatternSource" },
          "description": "All places this pattern can be found. Each source has a role (canonical, storefront, publication, etc.)."
        },
        "primary_source_id": { "type": "string", "description": "ID of the canonical source within sources[]" },

        "language": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Available languages (ISO 639-1)"
        },

        "size_options": {
          "type": "array",
          "items": { "$ref": "#/$defs/SizeOption" },
          "description": "Structured size options with measurements and material requirements per size."
        },
        "sizes": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Simple size labels (for when structured size_options are not available)"
        },
        "measurements": { "$ref": "#/$defs/Measurements" },

        "is_free": { "type": "boolean" },
        "price": { "$ref": "#/$defs/Money" },
        "downloadable": { "type": "boolean" },

        "notes": { "type": "string" },
        "photos": { "type": "array", "items": { "$ref": "#/$defs/Photo" } },
        "tags": { "type": "array", "items": { "type": "string" } },

        "suggested_materials": {
          "type": "array",
          "items": { "$ref": "#/$defs/SuggestedMaterial" }
        },
        "material_requirements_by_size": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "size_label": { "type": "string" },
              "materials": { "type": "array", "items": { "$ref": "#/$defs/SuggestedMaterial" } }
            }
          },
          "description": "Material requirements broken down by size (instead of global min/max)."
        },
        "yardage_min": { "type": "number" },
        "yardage_max": { "type": "number" },
        "meterage_min": { "type": "number" },
        "meterage_max": { "type": "number" },

        "community": { "$ref": "#/$defs/CommunityMetrics" },
        "external_ids": { "$ref": "#/$defs/ExternalIds" },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" },

        "knitting": {
          "type": "object",
          "properties": {
            "yarn_weight": { "type": "string" },
            "needle_sizes_mm": { "type": "array", "items": { "type": "number" } },
            "gauge": { "$ref": "#/$defs/Gauge" },
            "gauge_description": { "type": "string" },
            "construction": { "type": "string" },
            "techniques": { "type": "array", "items": { "type": "string" } }
          },
          "additionalProperties": true
        },
        "crochet": {
          "type": "object",
          "properties": {
            "yarn_weight": { "type": "string" },
            "hook_sizes_mm": { "type": "array", "items": { "type": "number" } },
            "gauge": { "$ref": "#/$defs/Gauge" },
            "gauge_description": { "type": "string" },
            "has_us_terminology": { "type": "boolean" },
            "has_uk_terminology": { "type": "boolean" },
            "construction": { "type": "string" },
            "stitch_types": { "type": "array", "items": { "type": "string" } },
            "techniques": { "type": "array", "items": { "type": "string" } },
            "pieces": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "count": { "type": "integer", "default": 1 }
                }
              }
            }
          },
          "additionalProperties": true
        },
        "sewing": {
          "type": "object",
          "properties": {
            "fabric_type": { "type": "string" },
            "fabric_yardage": { "type": "number" },
            "notions": { "type": "array", "items": { "type": "string" } },
            "seam_allowance_cm": { "type": "number" },
            "seam_allowance_included": { "type": "boolean" },
            "ease": { "type": "string" },
            "pattern_pieces": { "type": "integer" },
            "pattern_pieces_list": { "type": "array", "items": { "type": "string" } },
            "garment_type": { "type": "string" },
            "suggested_fabrics": { "type": "array", "items": { "type": "string" } },
            "notions_required": { "type": "array", "items": { "type": "string" } },
            "lining_required": { "type": "boolean" },
            "interfacing_required": { "type": "boolean" }
          },
          "additionalProperties": true
        },
        "weaving": {
          "type": "object",
          "properties": {
            "draft_type": { "type": "string" },
            "structure": { "type": "string" },
            "shafts_required": { "type": "integer" },
            "treadles_required": { "type": "integer" },
            "width_cm": { "type": "number" },
            "sett_epi": { "type": "number" },
            "picks_per_inch": { "type": "number" },
            "warp_yardage": { "type": "number" },
            "weft_yardage": { "type": "number" },
            "threading_draft": { "type": "array", "items": { "type": "integer" } },
            "tie_up": { "type": "array", "items": { "type": "array", "items": { "type": "boolean" } } },
            "treadling_sequence": { "type": "array", "items": { "type": "integer" } },
            "wif_reference": { "type": "string" },
            "finished_width_cm": { "type": "number" },
            "finished_length_cm": { "type": "number" }
          },
          "additionalProperties": true
        },
        "quilting": {
          "type": "object",
          "properties": {
            "quilt_sizes_available": { "type": "array", "items": { "type": "string" } },
            "block_pattern": { "type": "string" },
            "piecing_method": { "type": "string" },
            "techniques_used": { "type": "array", "items": { "type": "string" } },
            "precut_friendly": { "type": "array", "items": { "type": "string" } },
            "fabric_requirements": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "role": { "type": "string" },
                  "description": { "type": "string" },
                  "yardage_by_size": { "type": "object", "additionalProperties": { "type": "number" } }
                }
              }
            }
          },
          "additionalProperties": true
        },
        "embroidery": {
          "type": "object",
          "properties": {
            "technique": { "type": "string" },
            "design_width_cm": { "type": "number" },
            "design_height_cm": { "type": "number" },
            "stitch_count": { "type": "integer" },
            "stitches_used": { "type": "array", "items": { "type": "string" } },
            "thread_list": {
              "type": "array",
              "items": { "$ref": "#/$defs/ThreadListEntry" }
            },
            "fabric_recommendations": { "type": "array", "items": { "type": "string" } },
            "strands_used": { "type": "integer" }
          },
          "additionalProperties": true
        },
        "cross_stitch": {
          "type": "object",
          "properties": {
            "fabric_type": { "type": "string" },
            "recommended_fabric_count": { "type": "integer" },
            "design_width_stitches": { "type": "integer" },
            "design_height_stitches": { "type": "integer" },
            "finished_sizes": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "fabric_count": { "type": "integer" },
                  "width_cm": { "type": "number" },
                  "height_cm": { "type": "number" }
                }
              }
            },
            "thread_list": {
              "type": "array",
              "items": { "$ref": "#/$defs/ThreadListEntry" }
            },
            "colors_count": { "type": "integer" },
            "has_backstitch": { "type": "boolean" },
            "has_fractional_stitches": { "type": "boolean" },
            "has_blended_threads": { "type": "boolean" },
            "has_beading": { "type": "boolean" },
            "strands_used": { "type": "integer" },
            "chart_type": { "type": "string" }
          },
          "additionalProperties": true
        },
        "spinning": {
          "type": "object",
          "properties": {
            "fiber_type": { "type": "string" },
            "fiber_prep": { "type": "string" },
            "target_weight": { "type": "string" },
            "target_wpi": { "type": "number" },
            "target_tpi": { "type": "number" },
            "ply_structure": { "type": "string" },
            "drafting_method": { "type": "string" },
            "yardage_target": { "type": "number" }
          },
          "additionalProperties": true
        },
        "macrame": {
          "type": "object",
          "properties": {
            "cord_type": { "type": "string" },
            "cord_diameter_mm": { "type": "number" },
            "cord_length_meters": { "type": "number" },
            "cords_count": { "type": "integer" },
            "knot_types": { "type": "array", "items": { "type": "string" } },
            "mounting_width_cm": { "type": "number" },
            "finished_width_cm": { "type": "number" },
            "finished_length_cm": { "type": "number" }
          },
          "additionalProperties": true
        },
        "tatting": {
          "type": "object",
          "properties": {
            "method": { "type": "string", "enum": ["shuttle", "needle", "both"] },
            "thread_size": { "type": "string" },
            "shuttle_count": { "type": "integer" },
            "notation_style": { "type": "string", "enum": ["written", "diagram", "both"] },
            "has_split_rings": { "type": "boolean" },
            "finished_width_cm": { "type": "number" },
            "finished_height_cm": { "type": "number" }
          },
          "additionalProperties": true
        },
        "dyeing": {
          "type": "object",
          "properties": {
            "dye_type": { "type": "string" },
            "method": { "type": "string" },
            "dye_recipe": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "dye_name": { "type": "string" },
                  "percentage_owf": { "type": "number" }
                }
              }
            },
            "mordant": { "type": "string" },
            "suitable_fibers": { "type": "array", "items": { "type": "string" } },
            "water_temperature_c": { "type": "number" },
            "duration_minutes": { "type": "number" },
            "expected_color": { "type": "string" },
            "expected_color_hex": { "type": "string" }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },

    "ContributorRef": {
      "type": "object",
      "description": "A person or entity involved in creating the pattern. Replaces flat designer string with structured contributor model.",
      "required": ["name"],
      "properties": {
        "name": { "type": "string" },
        "id": { "type": "string", "description": "Designer entity ID for deduplication" },
        "url": { "type": "string", "format": "uri" },
        "role": {
          "type": "string",
          "description": "designer, tech-editor, translator, illustrator, photographer, sample-maker, author, co-designer"
        },
        "external_ids": { "$ref": "#/$defs/ExternalIds" }
      }
    },
    "CategoryRef": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "path": { "type": "array", "items": { "type": "string" } }
      }
    },
    "PatternSource": {
      "type": "object",
      "description": "Where this pattern can be found. Each source has a role describing its relationship to the pattern.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "role": {
          "type": "string",
          "description": "canonical (original publication), storefront (where to buy), publication (book/magazine appearance), owned-copy (user's copy), community-listing (platform listing)"
        },
        "type": {
          "type": "string",
          "enum": ["book", "magazine", "digital-download", "website", "ebook", "pamphlet"]
        },
        "url": { "type": "string", "format": "uri" },
        "published_date": { "type": "string", "format": "date" },
        "available": { "type": "boolean" }
      }
    },
    "SizeOption": {
      "type": "object",
      "description": "A structured size with body measurements, finished measurements, and ease.",
      "properties": {
        "label": { "type": "string", "description": "Size label: XS, S, M, L, XL, or numeric (36, 38, 40)" },
        "body_measurements": {
          "type": "object",
          "additionalProperties": { "type": "number" },
          "description": "Body measurements in cm. Keys: bust, waist, hip, head_circumference, foot_length, etc."
        },
        "finished_measurements": {
          "type": "object",
          "additionalProperties": { "type": "number" },
          "description": "Finished garment measurements in cm."
        },
        "ease": {
          "type": "object",
          "additionalProperties": { "type": "number" },
          "description": "Ease in cm per measurement (finished - body). Positive = positive ease."
        },
        "schematic_dimensions": {
          "type": "object",
          "additionalProperties": { "type": "number" },
          "description": "Schematic diagram dimensions in cm."
        },
        "material_requirements": {
          "type": "array",
          "items": { "$ref": "#/$defs/SuggestedMaterial" },
          "description": "Materials needed for this specific size."
        }
      }
    },
    "Measurements": {
      "type": "object",
      "description": "Measurement reference for the pattern (body, finished, schematic).",
      "properties": {
        "measurement_unit": { "type": "string", "enum": ["cm", "inches"], "default": "cm" },
        "body_measurement_keys": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Which body measurements this pattern uses (bust, waist, hip, head, foot_length, etc.)"
        },
        "schematic_uri": { "type": "string", "description": "URI to schematic diagram image" }
      }
    },
    "SuggestedMaterial": {
      "type": "object",
      "properties": {
        "product_id": { "type": "string" },
        "name": { "type": "string" },
        "brand": { "type": "string" },
        "weight_category": { "type": "string" },
        "quantity": {
          "type": "object",
          "properties": {
            "units_count": { "type": "number" },
            "unit_label": { "type": "string" },
            "length_meters": { "type": "number" }
          }
        },
        "colorway": { "type": "string" }
      }
    },
    "ThreadListEntry": {
      "type": "object",
      "description": "A thread/floss color entry for embroidery and cross-stitch patterns.",
      "properties": {
        "brand": { "type": "string" },
        "number": { "type": "string" },
        "name": { "type": "string" },
        "color_hex": { "type": "string" },
        "skeins": { "type": "number" }
      }
    },
    "CommunityMetrics": {
      "type": "object",
      "properties": {
        "rating_average": { "type": "number" },
        "rating_count": { "type": "integer" },
        "difficulty_average": { "type": "number" },
        "difficulty_count": { "type": "integer" },
        "favorites_count": { "type": "integer" },
        "projects_count": { "type": "integer" },
        "queued_count": { "type": "integer" }
      }
    },
    "Gauge": {
      "type": "object",
      "properties": {
        "stitches_per_unit": { "type": "number" },
        "rows_per_unit": { "type": "number" },
        "unit": { "type": "string" },
        "gauge_divisor": { "type": "integer" },
        "gauge_pattern": { "type": "string" }
      }
    },
    "Money": {
      "type": "object",
      "required": ["amount", "currency"],
      "properties": {
        "amount": { "type": "number" },
        "currency": { "type": "string", "minLength": 3, "maxLength": 3 }
      }
    },
    "Photo": {
      "type": "object",
      "required": ["uri"],
      "properties": {
        "id": { "type": "string" },
        "uri": { "type": "string" },
        "sort_order": { "type": "integer", "default": 0 },
        "is_primary": { "type": "boolean", "default": false },
        "caption": { "type": "string" },
        "copyright_holder": { "type": "string" },
        "aspect_ratio": { "type": "number" }
      }
    },
    "ExternalIds": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    }
  }
}
