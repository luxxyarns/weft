{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://weft.dev/schemas/v1.0/profiles/stash2go/favorite.schema.json",
  "title": "WEFT Favorite — Stash2Go Profile",
  "description": "Stash2Go profile of Favorite. Extends the base Favorite schema with Ravelry bookmark binding and type mapping.",
  "allOf": [
    { "$ref": "../../favorite.schema.json#/$defs/Favorite" },
    {
      "type": "object",
      "properties": {
        "external_ids": {
          "type": "object",
          "properties": {
            "stash2go": { "type": "string", "format": "uuid", "description": "Stash2Go internal UUID" },
            "ravelry": { "type": "string", "pattern": "^[0-9]+$", "description": "Ravelry bookmark ID" }
          }
        },

        "stash2go": {
          "type": "object",
          "description": "Stash2Go-specific fields that extend the generic WEFT Favorite.",
          "properties": {
            "ravelry_bookmark_id": {
              "type": "integer",
              "description": "Ravelry numeric bookmark ID."
            },
            "ravelry_bookmark_type": {
              "type": "string",
              "enum": ["pattern", "project", "yarn", "stash", "designer", "shop", "bundle", "forum_post", "yarn_company", "pattern_source"],
              "description": "Ravelry's bookmark type classification (maps to WEFT favorite.type)."
            },
            "ravelry_favorited_id": {
              "type": "integer",
              "description": "Ravelry numeric ID of the favorited entity."
            },
            "ravelry_updated_at": {
              "type": "string",
              "format": "date-time",
              "description": "Last known Ravelry update timestamp."
            },
            "device_id": {
              "type": "string",
              "description": "Device that created this favorite."
            }
          },
          "additionalProperties": true
        }
      }
    }
  ]
}
