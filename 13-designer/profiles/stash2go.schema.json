{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/luxxyarns/weft/blob/main/profiles/stash2go/designer.schema.json",
  "title": "WEFT Designer — Stash2Go Profile",
  "description": "Stash2Go profile of Designer. Extends the base Designer schema with Ravelry pattern_author linking and user account associations.",
  "allOf": [
    { "$ref": "../../designer.schema.json#/$defs/Designer" },
    {
      "type": "object",
      "properties": {
        "external_ids": {
          "type": "object",
          "properties": {
            "stash2go": { "type": "string", "format": "uuid", "description": "Stash2Go internal UUID" },
            "ravelry": { "type": "string", "pattern": "^[0-9]+$", "description": "Ravelry pattern_author ID" }
          }
        },

        "stash2go": {
          "type": "object",
          "description": "Stash2Go-specific fields that extend the generic WEFT Designer.",
          "properties": {
            "ravelry_pattern_author_id": {
              "type": "integer",
              "description": "Ravelry numeric pattern_author ID."
            },
            "ravelry_permalink": {
              "type": "string",
              "description": "Ravelry URL-safe permalink for this designer."
            },
            "linked_ravelry_users": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "username": { "type": "string", "description": "Ravelry username" },
                  "user_id": { "type": "integer", "description": "Ravelry numeric user ID" }
                }
              },
              "description": "Ravelry user accounts linked to this designer (a designer may have multiple user accounts)."
            },
            "ravelry_updated_at": {
              "type": "string",
              "format": "date-time",
              "description": "Last known Ravelry update timestamp."
            }
          },
          "additionalProperties": true
        }
      }
    }
  ]
}
