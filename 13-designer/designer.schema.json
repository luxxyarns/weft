{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://weft.dev/schemas/v1.0/designer.schema.json",
  "title": "WEFT Designer",
  "description": "Pattern designers, authors, and studios — the people and entities who create craft patterns.",
  "type": "object",
  "required": ["weft_version", "type", "items"],
  "properties": {
    "weft_version": { "type": "string", "const": "1.0" },
    "type": { "type": "string", "const": "designer" },
    "exported_at": { "type": "string", "format": "date-time" },
    "exported_from": {
      "type": "object",
      "properties": {
        "app": { "type": "string" },
        "version": { "type": "string" },
        "platform": { "type": "string" }
      }
    },
    "items": {
      "type": "array",
      "items": { "$ref": "#/$defs/Designer" }
    }
  },
  "$defs": {
    "Designer": {
      "type": "object",
      "required": ["id", "name"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "entity_type": {
          "type": "string",
          "enum": ["person", "studio", "brand"],
          "description": "Whether this is an individual, a design studio, or a company brand."
        },
        "bio": { "type": "string" },
        "url": { "type": "string", "format": "uri" },
        "country": { "type": "string" },
        "languages": { "type": "array", "items": { "type": "string" }, "description": "Languages the designer publishes in (ISO 639-1)" },
        "pronouns": { "type": "string" },
        "active_since": { "type": "string", "format": "date", "description": "When the designer started publishing" },
        "inactive_since": { "type": "string", "format": "date", "description": "When the designer stopped publishing (if applicable)" },
        "aliases": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Alternative names, former names, or studio variants for deduplication."
        },

        "roles": {
          "type": "array",
          "items": { "type": "string" },
          "description": "What this entity does: designer, tech-editor, translator, illustrator, photographer, sample-maker, author, publisher"
        },

        "members": {
          "type": "array",
          "items": { "$ref": "#/$defs/MemberRef" },
          "description": "For studios/brands: individual members/designers within the entity."
        },

        "patterns_count": { "type": "integer" },
        "knitting_pattern_count": { "type": "integer" },
        "crochet_pattern_count": { "type": "integer" },
        "favorites_count": { "type": "integer" },

        "shop_links": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string", "description": "Store name (e.g., 'Ravelry Store', 'Etsy', 'Own Website')" },
              "url": { "type": "string", "format": "uri" }
            }
          },
          "description": "Where to buy this designer's patterns. Separate from social links."
        },
        "social": {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "description": "Social media links. Keys: website, instagram, youtube, podcast, blog, etc."
        },

        "photos": { "type": "array", "items": { "$ref": "#/$defs/Photo" } },
        "external_ids": { "$ref": "#/$defs/ExternalIds" },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": true
    },
    "MemberRef": {
      "type": "object",
      "description": "A member of a studio or brand.",
      "properties": {
        "designer_id": { "type": "string", "description": "Reference to another Designer entity" },
        "name": { "type": "string" },
        "role": { "type": "string" }
      }
    },
    "Photo": {
      "type": "object",
      "required": ["uri"],
      "properties": {
        "id": { "type": "string" },
        "uri": { "type": "string" },
        "sort_order": { "type": "integer", "default": 0 },
        "is_primary": { "type": "boolean", "default": false },
        "caption": { "type": "string" },
        "copyright_holder": { "type": "string" },
        "aspect_ratio": { "type": "number" }
      }
    },
    "ExternalIds": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    }
  }
}
