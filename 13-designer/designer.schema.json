{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://weft.dev/schemas/v1.0/designer.schema.json",
  "title": "WEFT Designer",
  "description": "Pattern designers and authors.",
  "type": "object",
  "required": ["weft_version", "type", "items"],
  "properties": {
    "weft_version": { "type": "string", "const": "1.0" },
    "type": { "type": "string", "const": "designer" },
    "exported_at": { "type": "string", "format": "date-time" },
    "exported_from": {
      "type": "object",
      "properties": {
        "app": { "type": "string" },
        "version": { "type": "string" },
        "platform": { "type": "string" }
      }
    },
    "items": {
      "type": "array",
      "items": { "$ref": "#/$defs/Designer" }
    }
  },
  "$defs": {
    "Designer": {
      "type": "object",
      "required": ["id", "name"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "bio": { "type": "string" },
        "url": { "type": "string", "format": "uri" },
        "patterns_count": { "type": "integer" },
        "knitting_pattern_count": { "type": "integer" },
        "crochet_pattern_count": { "type": "integer" },
        "favorites_count": { "type": "integer" },
        "social": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "photos": { "type": "array", "items": { "$ref": "#/$defs/Photo" } },
        "external_ids": { "$ref": "#/$defs/ExternalIds" },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": true
    },
    "Photo": {
      "type": "object",
      "required": ["uri"],
      "properties": {
        "id": { "type": "string" },
        "uri": { "type": "string" },
        "sort_order": { "type": "integer", "default": 0 },
        "is_primary": { "type": "boolean", "default": false },
        "caption": { "type": "string" },
        "copyright_holder": { "type": "string" },
        "aspect_ratio": { "type": "number" }
      }
    },
    "ExternalIds": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    }
  }
}
